# MongoDB
MONGODB_URI=mongodb://mongodb:27017/virtual_comtor

# Soniox
SONIOX_API_KEY=your_soniox_api_key

# Auth
JWT_SECRET=change_this_to_a_random_string_min_32_chars
JWT_REFRESH_SECRET=change_this_to_another_random_string_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ElevenLabs (future)
# ELEVENLABS_API_KEY=your_elevenlabs_api_key

# OpenAI (meeting summary)
OPENAI_API_KEY=your_openai_api_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Storage
STORAGE_PATH=./Vcomtor/storage
